#!/usr/bin/env node
const { platform, arch, env } = process;

const PLATFORMS = {
  win32: {
    x64: "@pnpm/registry.win32-x64/pnpm-registry.exe",
    arm64: "@pnpm/registry.win32-arm64/pnpm-registry.exe",
  },
  darwin: {
    x64: "@pnpm/registry.darwin-x64/pnpm-registry",
    arm64: "@pnpm/registry.darwin-arm64/pnpm-registry",
  },
  linux: {
    x64: "@pnpm/registry.linux-x64/pnpm-registry",
    arm64: "@pnpm/registry.linux-arm64/pnpm-registry",
  },
};

const binPath = PLATFORMS?.[platform]?.[arch];
if (binPath) {
  const result = require("child_process").spawnSync(
    require.resolve(binPath),
    process.argv.slice(2),
    {
      shell: false,
      stdio: "inherit",
      env,
    }
  );

  if (result.error) {
    throw result.error;
  }

  process.exitCode = result.status;
} else {
  console.error(
    "The pnpm-registry package doesn't ship with prebuilt binaries for your platform yet. " +
    "You can create an issue at https://github.com/pnpm/pnpm/issues for support."
  );
  process.exitCode = 1;
}
