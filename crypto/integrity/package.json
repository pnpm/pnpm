  "devDependencies": {
    "@jest/globals": "catalog:",
    "@pnpm/crypto.integrity": "workspace:*"
  },
  "engines": {
    "node": ">=22.13"
  },
  "jest": {
    "preset": "@pnpm/jest-config"
  }
}
