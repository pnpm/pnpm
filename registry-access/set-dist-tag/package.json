{
  "name": "@pnpm/registry-access.set-dist-tag",
  "version": "1100.0.0",
  "description": "Low-level helper that PUTs a dist-tag to an npm registry",
  "keywords": [
    "pnpm",
    "pnpm11"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
  "repository": "https://github.com/pnpm/pnpm/tree/main/registry-access/set-dist-tag",
  "homepage": "https://github.com/pnpm/pnpm/tree/main/registry-access/set-dist-tag#readme",
  "bugs": {
    "url": "https://github.com/pnpm/pnpm/issues"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "!*.map"
  ],
  "scripts": {
