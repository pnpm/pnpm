{
  "name": "@pnpm/deps.inspection.commands",
  "version": "1000.0.0",
  "description": "The list, ll, why, and outdated commands of pnpm",
  "keywords": [
    "pnpm",
    "pnpm11"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
