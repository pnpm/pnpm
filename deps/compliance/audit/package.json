{
  "name": "@pnpm/deps.compliance.audit",
  "version": "1101.0.0",
  "description": "Audit a lockfile",
  "keywords": [
    "pnpm",
    "pnpm11",
    "audit"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
