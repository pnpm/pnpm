{
  "name": "@pnpm/building.rebuild-command",
  "version": "1000.0.0-0",
  "description": "Rebuild command implementation for pnpm",
  "keywords": [
    "pnpm",
    "pnpm11",
    "rebuild"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
  "repository": "https://github.com/pnpm/pnpm/tree/main/building/rebuild-command",
  "homepage": "https://github.com/pnpm/pnpm/tree/main/building/rebuild-command#readme",
  "bugs": {
    "url": "https://github.com/pnpm/pnpm/issues"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "!*.map"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "prepublishOnly": "pnpm run compile",
    "compile": "tsgo --build && pnpm run lint --fix",
    "test": "pnpm run compile"
  },
  "dependencies": {
    "@pnpm/building.after-install": "workspace:*",
    "@pnpm/cli.common-cli-options-help": "workspace:*",
    "@pnpm/cli.utils": "workspace:*",
    "@pnpm/config.reader": "workspace:*",
    "@pnpm/store.connection-manager": "workspace:*",
    "@pnpm/types": "workspace:*",
    "@pnpm/workspace.projects-sorter": "workspace:*",
    "p-limit": "catalog:",
    "ramda": "catalog:",
    "render-help": "catalog:"
  },
  "peerDependencies": {
    "@pnpm/logger": "catalog:"
  },
  "devDependencies": {
    "@pnpm/building.rebuild-command": "workspace:*",
    "@pnpm/logger": "workspace:*",
    "@types/ramda": "catalog:"
  },
  "engines": {
    "node": ">=22.13"
  },
  "jest": {
    "preset": "@pnpm/jest-config"
  }
}
