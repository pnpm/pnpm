  },
  "dependencies": {
    "@pnpm/constants": "workspace:*",
    "@pnpm/core-loggers": "workspace:*",
    "@pnpm/installing.modules-yaml": "workspace:*",
    "@pnpm/installing.read-projects-context": "workspace:*",
    "@pnpm/lockfile.fs": "workspace:*",
    "@pnpm/resolving.resolver-base": "workspace:*",
    "@pnpm/store.controller": "workspace:*",
    "@pnpm/types": "workspace:*",
    "path-absolute": "catalog:",
    "ramda": "catalog:"
  },
  "peerDependencies": {
    "@pnpm/logger": "catalog:"
  },
  "devDependencies": {
    "@pnpm/installing.context": "workspace:*",
    "@pnpm/logger": "workspace:*",
    "@types/ramda": "catalog:"
  },
  "engines": {
    "node": ">=22.13"
  },
  "jest": {
    "preset": "@pnpm/jest-config"
  }
}
