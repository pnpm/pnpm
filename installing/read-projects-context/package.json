{
  "name": "@pnpm/installing.read-projects-context",
  "version": "1100.0.3",
  "description": "Reads the current state of projects from modules manifest",
  "keywords": [
    "pnpm",
    "pnpm11"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
  "repository": "https://github.com/pnpm/pnpm/tree/main/installing/read-projects-context",
  "homepage": "https://github.com/pnpm/pnpm/tree/main/installing/read-projects-context#readme",
  "bugs": {
    "url": "https://github.com/pnpm/pnpm/issues"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "!*.map"
  ],
  "scripts": {
    "start": "tsgo --watch",
    "test": "pn compile",
    "lint": "eslint \"src/**/*.ts\"",
    "prepublishOnly": "tsgo --build",
    "compile": "tsgo --build && pn lint --fix"
  },
  "dependencies": {
    "@pnpm/config.normalize-registries": "workspace:*",
    "@pnpm/installing.modules-yaml": "workspace:*",
    "@pnpm/lockfile.fs": "workspace:*",
    "@pnpm/types": "workspace:*",
    "realpath-missing": "catalog:"
  },
  "peerDependencies": {
    "@pnpm/logger": "catalog:"
  },
  "devDependencies": {
    "@pnpm/installing.read-projects-context": "workspace:*",
    "@pnpm/logger": "workspace:*"
  },
  "engines": {
    "node": ">=22.13"
  },
  "jest": {
    "preset": "@pnpm/jest-config"
  }
}
