{
  "name": "@pnpm/shell.path",
  "version": "1100.0.0",
  "description": "Functions for changing PATH env variable",
  "keywords": [
    "pnpm",
    "pnpm11",
    "env"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
  "repository": "https://github.com/pnpm/pnpm/tree/main/shell/path",
  "homepage": "https://github.com/pnpm/pnpm/tree/main/shell/path#readme",
  "bugs": {
    "url": "https://github.com/pnpm/pnpm/issues"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "!*.map"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
