  "dependencies": {
    "path-name": "catalog:"
  },
  "devDependencies": {
    "@pnpm/shell.path": "workspace:*"
  },
  "engines": {
    "node": ">=22.13"
  },
  "jest": {
    "preset": "@pnpm/jest-config"
  }
}
