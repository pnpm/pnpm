#!/bin/sh
# Commit-message checks. Wired in via `git config core.hooksPath .githooks`
# (run by the root package's "prepare" script — see .githooks/install.mjs).
#
# Each check is a self-contained Node.js script with no npm dependencies, so
# the hook works in a fresh clone before `pnpm install` has run.
set -o errexit -o nounset

node .githooks/reject-bare-issue-refs.mjs "$1"
node .githooks/reject-bare-mentions.mjs "$1"
node .githooks/check-conventional-commit.mjs "$1"
