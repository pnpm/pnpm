{
  "name": "@pnpm/config.writer",
  "version": "1100.0.2",
  "description": "Functions for updating the configuration settings",
  "keywords": [
    "pnpm",
    "pnpm11",
    "config"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
