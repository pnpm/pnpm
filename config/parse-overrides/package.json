{
  "name": "@pnpm/config.parse-overrides",
  "version": "1100.0.0",
  "description": "Parse overrides",
  "keywords": [
    "pnpm",
    "pnpm11"
  ],
  "license": "MIT",
  "funding": "https://opencollective.com/pnpm",
  "repository": "https://github.com/pnpm/pnpm/tree/main/config/parse-overrides",
  "homepage": "https://github.com/pnpm/pnpm/tree/main/config/parse-overrides#readme",
  "bugs": {
    "url": "https://github.com/pnpm/pnpm/issues"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
