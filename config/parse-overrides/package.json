    "@pnpm/error": "workspace:*",
    "@pnpm/resolving.parse-wanted-dependency": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "catalog:",
    "@pnpm/config.parse-overrides": "workspace:*"
  },
  "engines": {
    "node": ">=22.13"
  },
  "jest": {
    "preset": "@pnpm/jest-config"
  }
